{
  "name": "@myorg/root",
  "version": "0.1.0",
  "description": "TypeScript monorepo template",
  "type": "module",
  "main": "dist/index.js",
  "private": true,
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "rimraf": "~6.0.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@spiky-panda/core": "^0.1.0",
    "tslib": "^2.8.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "workspaces": [
    "packages/**/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc -b --watch",
    "lint": "npm run lint:check",
    "lint:check": "eslint \"packages/**/src/**/*.{ts,tsx,js,json}\" --quiet",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "npm run format:check",
    "format:check": "prettier --check \"packages/**/src/**/*.{ts,tsx,js,json,scss,css}\"",
    "format:fix": "prettier --write \"packages/**/src/**/*.{ts,tsx,js,json,scss,css}\"",
    "bundle": "npm run bundle --workspace=@myorg/core && npm run bundle --workspace=@myorg/lib-a",
    "bundle:dev": "npm run bundle:dev --workspace=@myorg/core && npm run bundle:dev --workspace=@myorg/lib-a",
    "clean": "rimraf packages/dev/*/dist packages/dev/*/bundle *.tsbuildinfo"
  },
  "engines": {
    "node": ">=20.11.0 <23.0.0",
    "npm": ">=8.0.0"
  }
}
