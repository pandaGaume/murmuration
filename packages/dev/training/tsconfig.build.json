{
    "extends": "../../../tsconfig.build.json",

    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "paths": {
            "@dev/spiky-panda/*": ["dev/spiky-panda/dist/*"],
            "@dev/core/*": ["dev/core/dist/*"],
            "@dev/training/*": ["dev/training/src/*"]
        }
    },

    "references": [
        { "path": "../core/tsconfig.build.json" }
    ],

    "include": ["./src/**/*.ts", "./src/**/*.tsx"],
    "exclude": ["**/node_modules", "**/dist"]
}
